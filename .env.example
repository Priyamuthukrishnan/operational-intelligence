# Operational Intelligence — Environment Configuration Example
# Copy this file to .env and replace placeholders with actual values.

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Mistral AI ───────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
LLM_MODEL=mistral-small-latest

# ── Qdrant Vector Store ──────────────────────────────────────────────
QDRANT_URL=https://your-qdrant-instance-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=operational-summaries

# ── Clustering Parameters ────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.75
SIMILARITY_SEARCH_LIMIT=20
TIME_CLUSTER_MIN_INTERACTIONS=1
